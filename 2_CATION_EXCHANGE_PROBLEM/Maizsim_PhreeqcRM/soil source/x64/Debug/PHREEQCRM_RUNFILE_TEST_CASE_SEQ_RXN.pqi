# CUSTOM DATABASE AND INPUT FILE FOR 2DSOIl-PHREEQCRM INTEGRATION
# AUTHOR: ADITYA KAPOOR, NWC-UNL and USDA (ARS-REE)

# NOTES: Nitrate, Nitrite, Nitrous, Ammonium and 

 SOLUTION_MASTER_SPECIES
 [A]			[A]			0	[A]		1
 [B]			[B]			0	[B]		1
 [C]			[C]			0	[C]		1
 [D]			[D]			0	[D]		1

 

 SOLUTION_SPECIES
 	[A]    	    =   [A]
		log_k	0.0	
 	[B]    	    =   [B]
		log_k	0.0
 	[C]    	    =   [C]
		log_k	0.0
 	[D]    	    =   [D]
		log_k	0.0

END
 
 SOLUTION   0
 units   mmol/l
 density 1
 [A] 00.0
 [B] 00.0
 [C] 00.0
 [D] 00.0
 O(0)	0.5
 USE SOLUTION 0
 SAVE SOLUTION 0
 END

 KINETICS 0
	ABreaction
	-formula [A] -1 [B] +1  		# DELTA = PRODUCT - REACTANT ( EXAMPLE: NITRATE TO NITRITE )  

	BCreaction
	-formula [B] -1 [C] +1  		# DELTA = PRODUCT - REACTANT ( EXAMPLE: NITRATE TO NITRITE )  

	USER_PUNCH
	10 PRINT "KIN([A]):       ", KIN("[A]")
	20 PRINT "KIN([B]):       ", KIN("[B]")

 END

 RATES
	ABreaction
	-start
	10 A_CONC = MOL("[A]")
	20 REDOX_POTENTIAL = S-LA("e-")*(1000*2.303*8.3144*TK)/(96484)	# IN mV
	30 if (A_CONC>=1.0e-10) Then rate = 5.0e-9 ELSE rate = 0.0		# MOL IS MOLALITY (= MOLARITY IF DENSITY =1) OF A SPECIES IN MOLES/Kgw
	40 moles = 1*rate*TIME*SOLN_VOL
	50 SAVE moles
	-end

	BCreaction
	-start
	10 B_CONC = MOL("[B]")
	20 REDOX_POTENTIAL = S-LA("e-")*(1000*2.303*8.3144*TK)/(96484)	# IN mV
	30 if (B_CONC>=1.0e-10) Then rate = 1.0e-9 ELSE rate = 0.0		# MOL IS MOLALITY (= MOLARITY IF DENSITY =1) OF A SPECIES IN MOLES/Kgw
	40 moles = 1*rate*TIME*SOLN_VOL
	50 SAVE moles
	-end
  

 SOLUTION 1-670
 units   mmol/l
 density 1
 [A] 00.0
 [B] 00.0
 [C] 00.0
 [D] 00.0
 USE SOLUTION 0
 END

 KINETICS 1-670
	ABreaction
	-formula [A] -1 [B] +1  		# DELTA = PRODUCT - REACTANT ( EXAMPLE: NITRATE TO NITRITE )  

	BCreaction
	-formula [B] -1 [C] +1  		# DELTA = PRODUCT - REACTANT ( EXAMPLE: NITRATE TO NITRITE )  

	USER_PUNCH
	10 PRINT "KIN([A]):       ", KIN("[A]")
	20 PRINT "KIN([B]):       ", KIN("[B]")


 END

 SELECTED_OUTPUT
     -active     true
     -reset     false
     -file   PHREEQCRM_SELECTED_OUTPUT.sel
     -pH     true
     -pe     true
     -charge_balance     true
     -percent_error     true
#     -SOLN_VOL     true
     -water     true
     -totals	O(0)
     -kinetic_reactants   ABreaction BCreaction #Odecay

USER_PUNCH
-headings Eh
-start
10 REM convert to Eh
20 PUNCH S-LA("e-")*(1000*2.303*8.3144*TK)/(96484)
 -end

USER_PRINT
-start
10 PRINT "Solution defined pe:         ", pe
-end

 KNOBS
 -iterations 2000
 -tolerance 1e-20
